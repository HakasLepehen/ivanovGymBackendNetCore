# .editorconfig - настройки форматирования кода для C#

[*.cs]
# Отступы и пробелы
indent_style = space
indent_size = 4
tab_width = 4

# Использование {}
dotnet_style_require_accessibility_modifiers = for_interface_members:warning
dotnet_style_require_accessibility_modifiers = for_constructors_and_methods:warning
dotnet_style_require_accessibility_modifiers = for_properties_events_indexers:warning

# Пробелы вокруг операторов
dotnet_style_space_around_binary_operators = before_and_after:suggestion
dotnet_style_space_before_binary_operators = true
dotnet_style_space_after_binary_operators = true

# Пробелы в скобках
dotnet_style_space_within_parenthesis = false
dotnet_style_space_within_method_call_parentheses = false
dotnet_style_space_within_method_declaration_parentheses = false
dotnet_style_space_within_control_statement_parentheses = false
dotnet_style_space_within_bracket = false
dotnet_style_space_before_bracket = false
dotnet_style_space_after_bracket = false
dotnet_style_space_within_expression_list_parentheses = false
dotnet_style_space_before_colon_in_conditional = before_and_after:suggestion
dotnet_style_space_after_colon_in_conditional = before_and_after:suggestion

# Именование
# Классы, интерфейсы, делегаты
csharp_style_var_for_built_in_types = false:error
csharp_style_var_when_type_is_apparent = false:suggestion
csharp_style_var_when_type_is_not_apparent = false:suggestion

# Расположение операторов
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_prefer_method_group_conversion = true:suggestion

# Порядок using
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion

# Модификаторы
dotnet_style_readonly_field = true:suggestion
csharp_style_prefer_static_local_function = true:suggestion

# Выражения
csharp_style_prefer_switch_expression = true:error
csharp_style_prefer_pattern_matching = true:error
csharp_style_prefer_not_pattern = true:suggestion
csharp_style_prefer_index_operator = true:suggestion

# null-проверки
csharp_style_null_check_syntax = prefer_is_null_check:error

# Переменные
dotnet_style_predefined_type_for_locals_parameters_members = true:error
dotnet_style_predefined_type_for_member_access = true:error

# Style preferences
dotnet_style_coalesce_expression = true:error
dotnet_style_null_propagation = true:error
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:error

# Выражения-тела
csharp_style_expression_bodied_methods = true:suggestion
csharp_style_expression_bodied_constructors = false:error
csharp_style_expression_bodied_operators = false:error
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_indexers = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion

# Пустые строки
csharp_style_allow_embedded_statements_on_same_line_experimental = true:suggestion
csharp_style_allow_multiple_blank_lines_experimental = true:suggestion
csharp_style_allow_blank_lines_between_consecutive_braces = true:suggestion
csharp_style_allow_blank_line_after_colon_in_conditional_operator = true:suggestion

# Разделители
csharp_style_prefer_new_line_on_new_object_expressions = true:suggestion

# Доступность
csharp_style_prefer_readonly_struct = true:suggestion
csharp_style_prefer_record_struct = true:suggestion
